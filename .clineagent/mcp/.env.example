# ===== Architecture =====
# We use a hybrid approach:
# - COMPOSIO (cloud): GitHub, Gmail, Slack, Notion, and 1000+ other toolkits
# - Local servers: Filesystem, Docker, databases, browser automation

# ===== COMPOSIO (Primary - Cloud Proxy) =====
# COMPOSIO manages all cloud integrations. Configure toolkits at platform.composio.dev
COMPOSIO_API_KEY=your_composio_api_key_here

# ===== Local Servers =====
# These run on your machine and are NOT managed by COMPOSIO

# Database connections
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/db
REDIS_URL=redis://localhost:6379
SQLITE_DB_PATH=./data.db